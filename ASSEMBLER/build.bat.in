@echo off
REM Build script for USVFS Assembler
REM Generated by CMake

set NASM=%NASM%

echo Building USVFS Assembler...
echo.

REM Assemble all .asm files in src/
for %%f in (src\*.asm) do (
    echo Assembling %%~nf.asm...
    "%NASM%" -f win64 -o "obj\%%~nf.obj" "%%f"
)

echo.
echo Assembly complete!
echo.
echo Output files in obj/ directory:
dir /b obj\

echo.
echo To link these objects, use:
echo   link /NOLOGO /OUT:usvfs_asm.dll obj\*.obj
